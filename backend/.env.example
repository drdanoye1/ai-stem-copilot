# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/math_copilot

# JWT
SECRET_KEY=your-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Providers — at least one required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
DEFAULT_MODEL=gpt-4o

# Admin
# Comma-separated list of emails auto-promoted to admin on registration.
# The first email is also used by the one-time POST /api/v1/auth/setup endpoint.
ADMIN_EMAILS=admin@aimathcopilot.com
# Password for the admin account created via POST /api/v1/auth/setup
ADMIN_PASSWORD=your-strong-password-here
